{
  "llm": {
    "api_key": "",
    "model": "MiniMax-M2.7",
    "base_url": "https://api.minimaxi.com/v1",
    "timeout": 300
  },
  "plan_mode": {
    "allowed_bash_patterns": [
      "^firecrawl\\b",
      "^curl\\s+-s"
    ]
  },
  "context": {
    "enabled": true,
    "context_window_tokens": 200000,
    "reserve_output_tokens": 8000,
    "micro_compact": {
      "enabled": true,
      "keep_recent_tool_results": 3,
      "keep_recent_turns": 2,
      "compact_reasoning_after_turns": 1,
      "placeholder_max_chars": 400,
      "micro_compact_buffer_tokens": 8000
    },
    "auto_summarize": {
      "enabled": true,
      "threshold_buffer_tokens": 12000,
      "min_messages_before_summarize": 10,
      "max_consecutive_failures": 3
    },
    "summarize": {
      "keep_recent_messages": 6,
      "max_summary_output_tokens": 4096
    }
  },
  "memory": {
    "enabled": true,
    "memory_md_max_bytes": 25600,
    "memory_md_max_lines": 200,
    "warn_threshold_pct": 80
  },
  "sessions": {
    "enabled": false,
    "records_max_event_bytes": 100000,
    "search_default_limit": 3,
    "search_window": 5,
    "browse_limit": 10
  },
  "tools": {
    "read": {
      "max_file_bytes": 262144,
      "max_output_tokens": 8000
    },
    "max_tool_result_chars": 100000,
    "max_glob_files": 500
  }
}
